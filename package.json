{
	"name": "modern_graph_tool",
	"private": true,
	"version": "2.1.4",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"build:cdn": "node scripts/build-cdn.js",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"i18n:check": "node scripts/check-translations.js",
		"i18n:missing": "node scripts/check-translations.js --write",
		"i18n:apply": "node scripts/apply-translations.js",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run"
	},
	"devDependencies": {
		"@eslint/compat": "^2.1.0",
		"@eslint/js": "^10.0.1",
		"@inlang/paraglide-js": "^2.19.0",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.65.1",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/typography": "^0.5.20",
		"@tailwindcss/vite": "^4.3.1",
		"@types/d3": "^7.4.3",
		"@types/node": "^25",
		"@vitest/browser-playwright": "^4.1.9",
		"eslint": "^10.5.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.19.0",
		"globals": "^17.6.0",
		"playwright": "^1.61.0",
		"prettier": "^3.8.4",
		"prettier-plugin-svelte": "^4.1.1",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"svelte": "^5.56.3",
		"svelte-check": "^4.6.0",
		"tailwindcss": "^4.3.1",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.61.1",
		"vite": "^8.0.16",
		"vitest": "^4.1.9",
		"vitest-browser-svelte": "^2.1.1"
	},
	"dependencies": {
		"@lucide/svelte": "^1.18.0",
		"bits-ui": "^2.18.1",
		"d3": "^7.9.0",
		"svelte-sonner": "^1.1.1"
	},
	"engines": {
		"node": ">=20"
	},
	"tsconfig": {
		"exclude": [
			"node_modules"
		]
	},
	"overrides": {
		"uuid": "^14.0.0"
	}
}
